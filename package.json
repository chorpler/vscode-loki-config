{
  "name": "vscode-loki-config",
  "displayName": "Loki Config",
  "description": "Syntax highlighting for Mayo Clinic's Swift (Loki) proteomics pipeline config files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "lokiconfig",
      "aliases": ["Loki Config", "Swift Config", "lokiconfig", "swiftconfig"],
      "extensions": [".conf",".swiftconf",".lokiconf"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "lokiconfig",
      "scopeName": "source.lokiconfig",
      "path": "./syntaxes/lokiconfig.tmLanguage.json"
    }]
  }
}
