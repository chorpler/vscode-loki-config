{
  "name": "swift-config",
  "displayName": "Swift Config",
  "description": "Syntax highlighting for Swift config files",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "swiftconfig",
      "aliases": ["Swift Config", "swiftconfig"],
      "extensions": [".conf",".swiftconf"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "swiftconfig",
      "scopeName": "source.swiftconfig",
      "path": "./syntaxes/swiftconfig.tmLanguage.json"
    }]
  }
}
