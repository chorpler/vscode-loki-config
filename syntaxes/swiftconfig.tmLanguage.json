{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Swift Config",
  "scopeName": "source.swiftconfig",
  "fileTypes": [
    "swiftconf"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#section-end"
    },
    {
      "include": "#section-begin"
    },
    {
      "include": "#assignment-boolean"
    },
    {
      "include": "#assignment-number"
    },
    {
      "include": "#assignment-structured"
    },
    {
      "include": "#assignment-quoted"
    },
    {
      "include": "#assignment-generic"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.swiftconfig",
          "match": "^\\s*#.*$"
        }
      ]
    },
    "section-begin": {
      "patterns": [
        {
          "name": "meta.section.begin.swiftconfig",
          "match": "^(\\s*)(<)([A-Za-z_][\\w-]*)(?:\\s+([^>]+?))?(\\s*)(>)\\s*$",
          "captures": {
            "2": {
              "name": "punctuation.definition.tag.begin.swiftconfig"
            },
            "3": {
              "name": "entity.name.section.swiftconfig"
            },
            "4": {
              "name": "entity.name.instance.swiftconfig"
            },
            "6": {
              "name": "punctuation.definition.tag.end.swiftconfig"
            }
          }
        }
      ]
    },
    "section-end": {
      "patterns": [
        {
          "name": "meta.section.end.swiftconfig",
          "match": "^(\\s*)(</)([A-Za-z_][\\w-]*)(\\s*)(>)\\s*$",
          "captures": {
            "2": {
              "name": "punctuation.definition.tag.begin.swiftconfig"
            },
            "3": {
              "name": "entity.name.section.swiftconfig"
            },
            "5": {
              "name": "punctuation.definition.tag.end.swiftconfig"
            }
          }
        }
      ]
    },
    "assignment-boolean": {
      "patterns": [
        {
          "name": "meta.assignment.swiftconfig",
          "match": "^(\\s*)([A-Za-z_][\\w-]*)(\\.)?([\\w-]*)?(\\.)?([\\w-]*)?(\\s+)(true|false)(?:(\\s+)(#.*))?$",
          "captures": {
            "2": {
              "name": "variable.other.key.swiftconfig"
            },
            "3": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "4": {
              "name": "variable.other.key-part2.swiftconfig"
            },
            "5": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "6": {
              "name": "variable.other.key-part3.swiftconfig"
            },
            "8": {
              "name": "constant.language.boolean.swiftconfig"
            },
            "10": {
              "name": "comment.line.number-sign.swiftconfig"
            }
          }
        }
      ]
    },
    "assignment-number": {
      "patterns": [
        {
          "name": "meta.assignment.swiftconfig",
          "match": "^(\\s*)([A-Za-z_][\\w-]*)(\\.)?([\\w-]*)?(\\.)?([\\w-]*)?(\\s+)([-+]?\\d+(?:\\.\\d+)?(?:[eE][-+]?\\d+)?)(?:(\\s+)(#.*))?$",
          "captures": {
            "2": {
              "name": "variable.other.key.swiftconfig"
            },
            "3": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "4": {
              "name": "variable.other.key-part2.swiftconfig"
            },
            "5": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "6": {
              "name": "variable.other.key-part3.swiftconfig"
            },
            "8": {
              "name": "constant.numeric.swiftconfig"
            },
            "10": {
              "name": "comment.line.number-sign.swiftconfig"
            }
          }
        }
      ]
    },
    "assignment-structured": {
      "patterns": [
        {
          "name": "meta.assignment.swiftconfig",
          "match": "^(\\s*)([A-Za-z_][\\w-]*)(\\.)?([\\w-]*)?(\\.)?([\\w-]*)?(\\s+)(\\[[^\\n]*\\]|\\{[^\\n]*\\})(?:(\\s+)(#.*))?$",
          "captures": {
            "2": {
              "name": "variable.other.key.swiftconfig"
            },
            "3": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "4": {
              "name": "variable.other.key-part2.swiftconfig"
            },
            "5": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "6": {
              "name": "variable.other.key-part3.swiftconfig"
            },
            "8": {
              "name": "meta.structure.value.swiftconfig"
            },
            "10": {
              "name": "comment.line.number-sign.swiftconfig"
            }
          }
        }
      ]
    },
    "assignment-quoted": {
      "patterns": [
        {
          "name": "meta.assignment.swiftconfig",
          "match": "^(\\s*)([A-Za-z_][\\w-]*)(\\.)?([\\w-]*)?(\\.)?([\\w-]*)?(\\s+)((?:\\\"(?:\\\\.|[^\\\"])*\\\")|(?:'(?:\\\\.|[^'])*'))(?:(\\s+)(#.*))?$",
          "captures": {
            "2": {
              "name": "variable.other.key.swiftconfig"
            },
            "3": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "4": {
              "name": "variable.other.key-part2.swiftconfig"
            },
            "5": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "6": {
              "name": "variable.other.key-part3.swiftconfig"
            },
            "8": {
              "name": "string.quoted.swiftconfig"
            },
            "10": {
              "name": "comment.line.number-sign.swiftconfig"
            }
          }
        }
      ]
    },
    "assignment-generic": {
      "patterns": [
        {
          "name": "meta.assignment.swiftconfig",
          "match": "^(\\s*)([A-Za-z_][\\w-]*)(\\.)?([\\w-]*)?(\\.)?([\\w-]*)?(\\s+)(.*?)(?:(\\s+)(#.*))?$",
          "captures": {
            "2": {
              "name": "variable.other.key.swiftconfig"
            },
            "3": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "4": {
              "name": "variable.other.key-part2.swiftconfig"
            },
            "5": {
              "name": "variable.other.key-divider.swiftconfig"
            },
            "6": {
              "name": "variable.other.key-part3.swiftconfig"
            },
            "8": {
              "name": "string.unquoted.swiftconfig"
            },
            "10": {
              "name": "comment.line.number-sign.swiftconfig"
            }
          }
        }
      ]
    }
  }
}

